{
  "name": "DISCO DAPP",
  "version": "1.0.0",
  "private": "true",
  "description": "DISCO DAPP | Backend",
  "main": "dist/src/main.js",
  "engines": {
    "node": ">=16.x.x"
  },
  "scripts": {
    "lint": "eslint --ext .ts src/",
    "lint-fix": "eslint --ext .ts src/ --fix",
    "format": "prettier --write src/**/*.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "prebuild": "prisma generate",
    "build": "rimraf ./dist && tsc -p tsconfig.build.json",
    "check-formatting": "prettier --check src/**/*.ts",
    "test": "jest",
    "dev": "cross-env NODE_ENV=development rimraf ./dist && tsc-watch -p tsconfig.build.json --onSuccess \"nodemon ./dist/src/main.js\"",
    "prod": "cross-env NODE_ENV=production rimraf ./dist && tsc-watch -p tsconfig.build.json --onSuccess \"node ./dist/src/main.js\"",
    "test-cov": "jest --coverage",
    "seed": "npx ts-node prisma/seed/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.14",
    "@types/express-session": "^1.18.1",
    "@types/jest": "^29.2.3",
    "@types/json-schema": "^7.0.15",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mime-types": "^2.1.4",
    "@types/moment": "^2.11.29",
    "@types/node": "^18.19.81",
    "@types/node-cron": "^3.0.11",
    "@types/range-parser": "^1.2.7",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.28.0",
    "jest": "^29.3.1",
    "nodemon": "^3.1.9",
    "prettier": "^2.8.0",
    "prisma": "^6.15.0",
    "rimraf": "^3.0.2",
    "supertest": "^6.3.1",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.2",
    "tsc-watch": "^5.0.3"
  },
  "dependencies": {
    "@lighthouse-web3/sdk": "^0.4.2",
    "@prisma/client": "^6.15.0",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "ethers": "^6.15.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "fs": "^0.0.1-security",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "mime": "^4.0.6",
    "mime-types": "^2.1.35",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nft.storage": "^7.2.0",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "path": "^0.12.7",
    "socket.io": "^4.8.1",
    "typescript": "^5.8.2",
    "util": "^0.12.5",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "jest": {
    "preset": "ts-jest",
    "clearMocks": true,
    "coverageDirectory": "../coverage",
    "coverageProvider": "v8",
    "rootDir": "./src",
    "transform": {
      "^.+\\.(ts|tsx)?$": "ts-jest"
    }
  }
}
