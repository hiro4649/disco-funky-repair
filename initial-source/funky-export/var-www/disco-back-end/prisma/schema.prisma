// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  wallet_address    String              @unique() @db.VarChar(255)
  level             Int                 @db.Integer
  experience        Int                 @db.Integer
  updatedAt         DateTime            @default(now()) @db.Timestamp(6)
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  tickets           Int                 @default(0)
  rarity            Int                 @default(1)
  PrizeTransactions PrizeTransactions[]
  ownedToken        ownedToken[]
  LotteryTickets    LotteryTickets[]
  PointHistory      PointHistory[]
  IllustrationHistory IllustrationHistory[]
  ReferralCode      ReferralCode?       // One-to-one relationship
  ReferredBy        ReferralHistory[]   @relation("ReferredBy") // Users referred by this user
  ReferredUser      ReferralHistory[]   @relation("ReferredUser") // Users who referred this user
}

model Prize {
  id                Int                 @id @default(autoincrement())
  ca                String              @db.VarChar(255)
  token_name        String              @db.VarChar(255)
  symbol            String              @db.VarChar(255)
  price             Float               @db.DoublePrecision
  balance           Float               @db.DoublePrecision
  default_image     String              @db.Text
  icon              String              @db.Text
  decimals          Int                 @db.Integer
  listed_DEX        String              @db.VarChar(255)
  telegram          String?             @db.VarChar(255)
  twitter           String?             @db.VarChar(255)
  discord           String?             @db.VarChar(255)
  ranking           Int                 @db.Integer
  quantity          Int                 @db.Integer
  real_probability  Float               @db.DoublePrecision
  probability       Float               @db.DoublePrecision
  saved_probability Float               @db.DoublePrecision
  earned_pts        Int                 @db.Integer
  flag              Boolean             @default(false)
  updatedAt         DateTime            @default(now()) @db.Timestamp(6)
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  PrizeTransactions PrizeTransactions[]
}

model TokenDetail {
  id                   Int      @id @default(autoincrement())
  ca                   String   @unique @db.VarChar(255)
  listed_DEX           String   @db.VarChar(255)
  token_symbol         String   @db.VarChar(255)
  price                Float    @db.DoublePrecision // convert SUI (native)
  price_usd            Float    @db.DoublePrecision // convert USDT 
  fdv                  Float    @db.DoublePrecision
  holders              Float    @db.DoublePrecision
  market_cap           Float    @db.DoublePrecision
  circulating_supply   Float    @db.DoublePrecision
  max_supply           Float    @db.DoublePrecision
  total_supply         Float    @db.DoublePrecision
  scarcityScore        Float    @db.DoublePrecision
  totalVolume          Float    @db.DoublePrecision
  volume_24h           Float    @db.DoublePrecision
  liquidity            Float    @db.DoublePrecision
  tradeVolumeRatio     Float    @db.DoublePrecision
  tradeVolumeRatio_dex Float    @db.DoublePrecision
  txns                 Float    @db.DoublePrecision
  txns_24h             Float    @db.DoublePrecision
  updatedAt            DateTime @default(now()) @db.Timestamp(6)
  createdAt            DateTime @default(now()) @db.Timestamp(6)
}

model Admin {
  id            Int      @id @default(autoincrement())
  email         String   @unique() @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  updatedAt     DateTime @default(now()) @db.Timestamp(6)
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  AirdropTokens AirdropTokens[]
}

model PrizeTransactions {
  id               Int       @id @default(autoincrement())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  prize            Prize     @relation(fields: [prizeId], references: [id], onDelete: Cascade)
  prizeId          Int
  tx_hash          String?   @db.VarChar(255)
  probability_time DateTime  @db.Timestamp(6)
  end_time         DateTime?
  status           Status    @default(READY)
}

model ownedToken {
  id                  Int   @id @default(autoincrement())
  userId              Int   @unique
  sixHourTokenBalance Float @db.DoublePrecision
  tallyTokenBalance   Float @db.DoublePrecision
  weeklyTokenBalance  Float @default(0) @db.DoublePrecision
  user                User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LotteryTickets {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  ticket       Int      @default(0)
  receivedDate DateTime @db.Timestamp(6)
}

model PointHistory {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason       Int      @default(1) @db.Integer // 1: Daily Bonus, 2: Prize Bonus, 3: NFT Bonus
  userId       Int
  point        Int      @default(0)
  receivedDate DateTime @db.Timestamp(6)
}

model AirdropTokens {
  id        Int      @id @default(autoincrement())
  admin     Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  balance   Int      @default(10000)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
}

model Nft {
  id           Int      @id @default(autoincrement())
  holderId     Int?     @db.Integer
  name         String   @db.Text
  creator      String   @db.VarChar(255)
  owner        String   @db.VarChar(255)
  description  String   @db.Text
  image        String   @db.Text
  royalty      Float    @db.DoublePrecision
  attributes   Json     @db.Json
  collectionId String   @db.Text
  externalUrl  String?  @db.Text
  ipfsCid      String?  @db.Text
  mintStatus   Boolean  @default(false)
  uploadStatus Boolean  @default(false)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
}

model SetTicketDistribute {
  id        Int      @id @default(autoincrement())
  day       Int?     @db.Integer
  hour      Int?     @db.Integer
  minutes   Int?     @db.Integer
  weekly    Boolean  @default(false)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
}

model News {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String   @db.Text
  image_url String?  @db.Text
  updatedAt DateTime @default(now()) @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
}

model Illustration {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String   @db.Text
  image_url   String?  @db.Text
  earned_pts  Int      @default(0)
  rarity      Int      @default(1)
  rarity_style String  @default("") @db.Text
  probability Float    @default(0)
  jumpStatus  Boolean  @default(false)
  updatedAt   DateTime @default(now()) @db.Timestamp(6)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  IllustrationHistory IllustrationHistory[]
}

model IllustrationHistory {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  illustration Illustration @relation(fields: [illustrationId], references: [id], onDelete: Cascade)
  illustrationId Int
  updatedAt      DateTime @default(now()) @db.Timestamp(6)
  createdAt      DateTime @default(now()) @db.Timestamp(6)
}

model ReferralCode {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int      @unique
  code         String   @unique @db.VarChar(255)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)
}

model ReferralHistory {
  id              Int      @id @default(autoincrement())
  referrer        User     @relation("ReferredBy", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId      Int
  referredUser    User     @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referredUserId  Int
  referralCode    String   @db.VarChar(255)
  rewarded        Boolean  @default(false)
  rewardAmount    Int      @default(100)
  timestampFirstLogin DateTime @db.Timestamp(6)
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @db.Timestamp(6)

  @@unique([referrerId, referredUserId])
}

enum Status {
  READY
  SENDING
  RECEIVED
}
